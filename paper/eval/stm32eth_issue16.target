# Reconstruction of stm32-rs/stm32-eth issue #16 ("Document possible problems
# when placing buffers on a cacheable region"). On an M7 the TX/RX descriptor
# ring and buffers default into cacheable AXI SRAM; the driver's own resolution
# was to REQUIRE they not be placed in a dcache-enabled region. BML enforces that
# at compile time and generates the non-cacheable MPU region.
arch = armv7em
cpu = cortex-m7
data_block = sram1
has_mpu = true
[mem.flash]
base = 0x08000000
size = 1M
[mem.sram1]
base = 0x24000000
size = 256K
[agent.cpu]
kind = cpu
reach = *
cached = true
[agent.eth]
kind = dma
reach = sram1
cached = false
handoff = Eth.DMATDLAR
[region.eth_ring]
mem = sram1
agents = eth

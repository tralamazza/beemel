# Nordic nRF5x hazard: EasyDMA is an AHB master to Data RAM only and "is not
# able to access the Flash" (Nordic Product Spec). A TX buffer in flash fails
# (HardFault / silent corruption today).
arch = armv6m
cpu = cortex-m0
data_block = ram
vector_table_offset = 0x00000000
[mem.flash]
base = 0x00000000
size = 256K
[mem.ram]
base = 0x20000000
size = 16K
[agent.cpu]
kind = cpu
reach = *
[agent.easydma]
kind = dma
reach = ram
handoff = Uarte.TXD_PTR
[region.tx_buf]
mem = flash
agents = easydma

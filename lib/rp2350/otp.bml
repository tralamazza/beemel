    }
    // Word 1 (bits 63..32) of the key. Write only, read returns 0x0
    reg CRT_KEY_W1 offset 0x13C {
        field CRT_KEY_W1: u32 bit[0..31] writeonly
    }
    // Word 2 (bits 95..64) of the key. Write only, read returns 0x0
    reg CRT_KEY_W2 offset 0x140 {
        field CRT_KEY_W2: u32 bit[0..31] writeonly
    }

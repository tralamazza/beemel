    // Interrupt status after masking & forcing
    reg INTS offset 0x170 {
        field APB_RD_NSEC_FAIL: b1 bit[4] readonly
        field APB_RD_SEC_FAIL: b1 bit[3] readonly
        field APB_DCTRL_FAIL: b1 bit[2] readonly
        field SBPI_WR_FAIL: b1 bit[1] readonly
        field SBPI_FLAG_N: b1 bit[0] readonly
    }
}


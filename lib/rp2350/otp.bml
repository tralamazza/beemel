    // Interrupt Force
    reg INTF offset 0x16C {
        field APB_RD_NSEC_FAIL: b1 bit[4]
        field APB_RD_SEC_FAIL: b1 bit[3]
        field APB_DCTRL_FAIL: b1 bit[2]
        field SBPI_WR_FAIL: b1 bit[1]
        field SBPI_FLAG_N: b1 bit[0]

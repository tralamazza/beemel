    reg DEBUGEN_LOCK offset 0x154 {
        field MISC: b1 bit[8]  // Write 1 to lock the MISC bit of DEBUGEN. Can't be cleared once set.
        field PROC1_SECURE: b1 bit[3]  // Write 1 to lock the PROC1_SECURE bit of DEBUGEN. Can't be cleared once set.
        field PROC1: b1 bit[2]  // Write 1 to lock the PROC1 bit of DEBUGEN. Can't be cleared once set.
        field PROC0_SECURE: b1 bit[1]  // Write 1 to lock the PROC0_SECURE bit of DEBUGEN. Can't be cleared once set.
        field PROC0: b1 bit[0]  // Write 1 to lock the PROC0 bit of DEBUGEN. Can't be cleared once set.

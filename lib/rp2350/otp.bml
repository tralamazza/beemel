    reg ARCHSEL_STATUS offset 0x15C {
        field CORE1: b1 bit[1] readonly  // Current architecture for core 0. Updated on processor warm reset.; arm=0, riscv=1
        field CORE0: b1 bit[0] readonly  // Current architecture for core 0. Updated on processor warm reset.; arm=0, riscv=1

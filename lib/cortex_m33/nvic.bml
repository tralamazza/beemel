// Cortex-M33 NVIC -- an ARM-defined core peripheral, shared across any
// Cortex-M33 part. Vendor SVDs omit the ARM core block (it lives in CMSIS-Core),
// so it is hand-written here rather than generated. Minimal set; extend as
// projects need it.
//
// Per-core PPB, BANKED: each core enables interrupts in its OWN copy -- the
// enable's location decides which core takes the IRQ.
peripheral NVIC at 0xE000E100 {
    reg ISER offset 0x000 {
        field BITS: u32 bit[0..31]
    }
}

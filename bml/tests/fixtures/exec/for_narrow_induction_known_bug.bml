// KNOWN BUG: a for-loop with a narrow (u8/i8/u16) induction variable
// miscompiles. The induction update is computed in i32 and then stored back to
// the i8 slot (`store i8 <i32>`), which llc rejects. Expected: compute the step
// in the induction variable's own width. This also blocks the documented
// step-1 type-boundary-safety guarantee for narrow counters.
import harness.semihost;

fn main() @context(thread) {
    // step == 1 should be safe at the u8 boundary: visits 250..254 -> 5 iters
    var cnt: u32 = 0;
    for n: u8 in 250 upto 255 {
        cnt = cnt + 1;
    }
    expect_u32(cnt, 5);
    done();
}

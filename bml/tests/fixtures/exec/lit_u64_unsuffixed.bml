// Regression test for a fixed bug: an unsuffixed integer literal in a 64-bit
// context used to be materialized at i32 width and zero-extended, silently
// truncating any value above 2^32-1 (`var a: u64 = 4294967296` lowered to
// `add i32 0, 4294967296` -> 0, then `zext .. to i64`). The literal is now
// emitted at 64 bits in a 64-bit context, matching the documented
// context-typed-literal behavior (see narrow_literals.bml).
import harness.semihost;

fn main() @context(thread) {
    var a: u64 = 4294967296; // 2^32, unsuffixed
    semihost.expect_u64(a, 4294967296u64);

    var b: u64 = 18446744073709551615; // u64::MAX, unsuffixed
    semihost.expect_u64(b, 18446744073709551615u64);

    semihost.done();
}

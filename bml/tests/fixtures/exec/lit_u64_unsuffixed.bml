// KNOWN BUG (pinned via known_bug!): an unsuffixed integer literal in a 64-bit
// context is evaluated at i32 width and zero-extended, silently truncating any
// value above 2^32-1. `var a: u64 = 4294967296` lowers to `add i32 0, 4294967296`
// (which truncates to 0) then `zext i32 .. to i64`, so `a` becomes 0.
//
// This contradicts the documented context-typed-literal behavior (see
// narrow_literals.bml): the context type narrows literals for small types but
// is not propagated to widen the constant's evaluation to 64 bits. A suffixed
// `4294967296u64` lowers correctly to `add i64`. When fixed, this passes under
// `cargo test --test exec -- --ignored`.
import harness.semihost;

fn main() @context(thread) {
    var a: u64 = 4294967296; // 2^32, unsuffixed
    expect_u64(a, 4294967296u64);

    var b: u64 = 18446744073709551615; // u64::MAX, unsuffixed
    expect_u64(b, 18446744073709551615u64);

    done();
}

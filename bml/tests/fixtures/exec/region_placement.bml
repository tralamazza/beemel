// `in <region>` places a static at its region's mem block address. The linker
// script (mem-block-driven when regions exist) must map the `.region.pool`
// section to the dma_pool block at 0x20001800, distinct from where ordinary
// statics land (.data/.bss in the sram block, below 0x20001800). Checked by the
// runtime addresses under QEMU. See doc/regions-agents.md slice 1.
import harness.semihost;

// Region memory is uninitialized at startup, so a region static takes no
// initializer (E601); it is written before use, like a DMA buffer. NORMAL_BUF
// is an ordinary static for the address comparison.
var POOL_BUF: [u32; 4] in pool;
var NORMAL_BUF: [u32; 4] = [0u32, 0u32, 0u32, 0u32];

fn main() @context(thread) {
    // pool is an agent-shared region (the dma agent reaches dma_pool), so
    // POOL_BUF is index-read-protected (derived-Move wraps it in Type::Dma).
    // Take the array base address (== &element 0), not `&POOL_BUF[0]`.
    const pool_addr = &POOL_BUF as u32;
    const normal_addr = (&NORMAL_BUF[0]) as u32;

    // The placed buffer sits in the dma_pool block [0x20001800, 0x20002000)
    // -- inside the 8K the QEMU machine actually maps, so the write/read-back
    // below exercises real memory (the old 0x20004000 location was unmapped
    // and the round-trip silently hung).
    semihost.expect_b1(pool_addr >= 0x20001800, true);
    semihost.expect_b1(pool_addr < 0x20002000, true);

    // An ordinary static lands in the working RAM block, below the pool.
    semihost.expect_b1(normal_addr < 0x20001800, true);

    // Placement does not disturb usability: the buffer still reads back writes.
    // The write goes directly; the read-back goes through a raw `*u32` view, the
    // same idiom the ETH descriptor code uses for agent-shared memory.
    POOL_BUF[1] = 0xCAFE;
    const pool_ptr = &POOL_BUF as *u32;
    semihost.expect_u32(pool_ptr[1], 0xCAFE);

    semihost.done();
}

// `in <region>` places a static at its region's mem block address. The linker
// script (mem-block-driven when regions exist) must map the `.region.pool`
// section to the dma_pool block at 0x20004000, distinct from where ordinary
// statics land (.data/.bss in the sram block, below 0x20004000). Checked by the
// runtime addresses under QEMU. See doc/regions-agents-plan.md slice 1.
import harness.semihost;

// Region memory is uninitialized at startup, so a region static takes no
// initializer (E601); it is written before use, like a DMA buffer. NORMAL_BUF
// is an ordinary static for the address comparison.
var POOL_BUF: [u32; 4] in pool;
var NORMAL_BUF: [u32; 4] = [0u32, 0u32, 0u32, 0u32];

fn main() @context(thread) {
    const pool_addr = (&POOL_BUF[0]) as u32;
    const normal_addr = (&NORMAL_BUF[0]) as u32;

    // The placed buffer sits in the dma_pool block [0x20004000, 0x20005000).
    expect_b1(pool_addr >= 0x20004000, true);
    expect_b1(pool_addr < 0x20005000, true);

    // An ordinary static lands in the working RAM block, below the pool.
    expect_b1(normal_addr < 0x20004000, true);

    // Placement does not disturb usability: the buffer still reads back writes.
    POOL_BUF[1] = 0xCAFE;
    expect_u32(POOL_BUF[1], 0xCAFE);

    done();
}

// Logical and bitwise operators. `||` and `&&` are distinct operations;
// bitwise &/|/^ operate at the value width and `~` complements at that width.
import harness.semihost;

fn main() @context(thread) {
    // logical
    semihost.expect_b1(true || false, true);
    semihost.expect_b1(false || false, false);
    semihost.expect_b1(false || true, true);
    semihost.expect_b1(true && false, false);
    semihost.expect_b1(true && true, true);

    // bitwise
    semihost.expect_u32(0xF0 & 0x0F, 0);
    semihost.expect_u32(0xF0 | 0x0F, 0xFF);
    semihost.expect_u32(0xFF ^ 0x0F, 0xF0);

    // bitwise NOT complements at the operand width: ~0u8 = 0xFF
    var z: u8 = 0u8;
    semihost.expect_u32((~z) as u32, 0xFF);

    semihost.done();
}

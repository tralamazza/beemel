// Inline asm with GCC/LLVM-style operands:
//   asm { template using $0, $1, ... } : outputs : inputs : clobbers
// Outputs (constraint starts with `=`) are returned by the asm and stored into
// their lvalues; inputs are passed in; clobbers list `memory`/`cc`/registers.
// Operands are numbered outputs-first then inputs, per LLVM.
import harness.semihost;

fn main() @context(thread) {
    // output only
    var a: u32 = 0;
    asm { movs $0, #42 } : "=r"(a);
    semihost.expect_u32(a, 42);

    // one input, one output: b = c + 1
    var c: u32 = 100;
    var b: u32 = 0;
    asm { adds $0, $1, #1 } : "=r"(b) : "r"(c);
    semihost.expect_u32(b, 101);

    // two outputs (struct return) from a two-instruction template
    var x: u32 = 0;
    var y: u32 = 0;
    asm { movs $0, #7
          movs $1, #9 } : "=r"(x), "=r"(y);
    semihost.expect_u32(x, 7);
    semihost.expect_u32(y, 9);

    // input-only with a memory clobber (a data barrier)
    asm { dmb } : : : "memory";

    semihost.done();
}

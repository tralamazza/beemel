import harness.semihost;

const LUT: [u32; 4] = [11u32, 22u32, 33u32, 44u32];

// A static aggregate initialized by naming a const aggregate (issue #4): the
// static is loaded at runtime, so a wrong `0` initializer would be observable.
var FROM_CONST: [u32; 4] = LUT;

// A float const initialized by naming another float const (issue #6).
const HALF7: f32 = 3.5f;
const HALF7_ALIAS: f32 = HALF7;

// Opaque identity defeats constant-folding so the read goes through the global.
fn idf(x: f32) -> f32 { return x; }

fn main() @context(thread) {
    expect_u32(FROM_CONST[0u32], 11);
    expect_u32(FROM_CONST[3u32], 44);
    expect_u32(idf(HALF7_ALIAS) as u32, 3); // 3.5 truncates to 3
    done();
}

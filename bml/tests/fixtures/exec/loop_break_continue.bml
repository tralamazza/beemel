// Infinite-`loop` runtime behavior (language.md §11).
//
// `loop` is a distinct lowering branch from `while` (ir.rs), but only `while`
// had an exec test (control_flow.bml); `loop` was exercised at check/borrow
// level only. This runs a `loop` under QEMU and checks both exit paths:
// `break` terminates the loop, and `continue` skips the rest of the iteration.
import harness.semihost;

fn main() @context(thread) {
    // Sum i over 1..=9, skipping 3 via `continue`, leaving the loop with
    // `break` at i == 10: 1+2+4+5+6+7+8+9 = 42.
    var i: u32 = 0u32;
    var sum: u32 = 0u32;
    loop {
        i = i + 1u32;
        if i == 10u32 {
            break;
        }
        if i == 3u32 {
            continue;
        }
        sum = sum + i;
    }
    semihost.expect_u32(i, 10u32); // break fired at exactly 10
    semihost.expect_u32(sum, 42u32); // continue skipped i == 3

    semihost.done();
}

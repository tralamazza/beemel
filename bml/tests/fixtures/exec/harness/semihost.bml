// Minimal ARM semihosting harness for QEMU execution tests.
//
// Execution fixtures import this module, compute a value, and self-check it
// against the spec-mandated answer with `expect_u32` / `expect_b1`. Each check
// prints "OK\n" on success or "FAIL got=0x.. want=0x..\n" on mismatch through
// semihosting SYS_WRITE0; the Rust harness asserts the captured output contains
// "OK" and never "FAIL". `done()` ends the run via SYS_EXIT so QEMU terminates
// instead of spinning in the reset loop.
//
// Kept deliberately tiny and obviously correct: it is the oracle path, so a bug
// here would surface immediately across every fixture. Note the pass/fail
// verdict is decided solely by the direct `actual == expected` comparison; the
// hex formatter is used only to render the failing values, so even if shifts or
// indexing were miscompiled the verdict stays trustworthy -- only the printed
// detail could be wrong.

// Generic semihosting trap. Per AAPCS the operation goes in r0 and the
// parameter in r1, exactly where the two arguments already sit at the trap.
fn semihost(op: u32, param: u32) {
    asm {
        bkpt 0xAB
    }
}

// SYS_WRITE0: write a NUL-terminated string. BML string literals are emitted
// NUL-terminated, so they can be passed straight through.
fn write0(msg: *u8) {
    semihost(0x04, msg as u32);
}

export fn ok() {
    write0("OK\n");
}

export fn fail() {
    write0("FAIL\n");
}

// Write `val` as "0x" followed by 8 hex digits. Uses a fixed 11-byte buffer
// ("0x" + 8 digits + NUL). 48 is '0', 87 makes 10..15 land on 'a'..'f'.
fn write_hex(n: u32) {
    var buf: [u8; 11] = [0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8];
    buf[0] = 48u8;
    buf[1] = 120u8;
    for i: u32 in 0 upto 8 {
        var nib: u32 = (n >> ((7 - i) * 4)) & 15;
        var c: u32 = if nib < 10 { nib + 48 } else { nib + 87 };
        buf[2 + i] = c as u8;
    }
    buf[10] = 0u8;
    write0(&mut buf[0]);
}

export fn expect_u32(actual: u32, expected: u32) {
    if actual == expected {
        ok();
    } else {
        write0("FAIL got=");
        write_hex(actual);
        write0(" want=");
        write_hex(expected);
        write0("\n");
    }
}

// Like `expect_u32` but for 64-bit values. The verdict is the direct `u64 ==`;
// the failing value is dumped as two 32-bit hex words (high then low), so even
// if the shift/truncate used only for that dump were wrong the verdict holds.
export fn expect_u64(actual: u64, expected: u64) {
    if actual == expected {
        ok();
    } else {
        write0("FAIL got=");
        write_hex((actual >> 32) as u32);
        write_hex(actual as u32);
        write0(" want=");
        write_hex((expected >> 32) as u32);
        write_hex(expected as u32);
        write0("\n");
    }
}

export fn expect_b1(actual: b1, expected: b1) {
    if actual == expected {
        ok();
    } else {
        // Map to 0/1 by branching rather than `b1 as u32`, so the harness does
        // not depend on the bool-to-int cast path it might be checking.
        write0("FAIL got=");
        write_hex(if actual { 1u32 } else { 0u32 });
        write0(" want=");
        write_hex(if expected { 1u32 } else { 0u32 });
        write0("\n");
    }
}

// SYS_EXIT with ADP_Stopped_ApplicationExit -> QEMU exits cleanly.
export fn done() {
    semihost(0x18, 0x20026);
}

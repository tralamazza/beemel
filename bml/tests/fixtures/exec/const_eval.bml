// Compile-time constants (language.md §1): a const participates in arithmetic
// and drives a loop bound, yielding the expected runtime values. (Using a const
// as an array length lives in a known-bug fixture: it currently evaluates to 0.)
import harness.semihost;

const SCALE: u32 = 10;
const LEN: u32 = 4;

fn main() @context(thread) {
    var arr: [u32; 4] = [1, 2, 3, 4];
    expect_u32(arr[3], 4);

    // const in arithmetic
    expect_u32(SCALE * 3, 30);

    // const as a loop bound; sum of arr = 10
    var sum: u32 = 0;
    for i: u32 in 0 upto LEN {
        sum = sum + arr[i];
    }
    expect_u32(sum, 10);

    done();
}

// Struct semantics (language.md §6): packed layout, field read/write, copy
// semantics (all-Copy structs duplicate on assignment), nested fields, sizeof.
import harness.semihost;

struct Point {
    x: u32,
    y: u32,
}

struct Line {
    a: Point,
    b: Point,
}

fn main() @context(thread) {
    var p = Point { x: 10, y: 20 };
    semihost.expect_u32(p.x, 10);
    semihost.expect_u32(p.y, 20);

    p.x = 30;
    semihost.expect_u32(p.x, 30);

    // copy semantics: assigning duplicates; mutating the copy leaves the original
    var q = p;
    q.x = 99;
    semihost.expect_u32(p.x, 30);
    semihost.expect_u32(q.x, 99);

    // nested struct field access
    var ln = Line { a: Point { x: 1, y: 2 }, b: Point { x: 3, y: 4 } };
    semihost.expect_u32(ln.a.y, 2);
    semihost.expect_u32(ln.b.x, 3);

    // packed layout: no padding between u32 fields
    semihost.expect_u32(sizeof(Point), 8);
    semihost.expect_u32(sizeof(Line), 16);

    semihost.done();
}

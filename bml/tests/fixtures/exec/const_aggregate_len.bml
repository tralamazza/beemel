import harness.semihost;

const FB: [u32; 6] = [10u32, 20u32, 30u32, 40u32, 50u32, 60u32];
const FB_LEN: u32 = len(FB);
const STRIDE_LEN: u32 = len(view(FB, stride 2));

struct Pair {
    a: u32,
    b: u32,
}

const PAIR: Pair = Pair { a: 7u32, b: FB_LEN };

fn main() @context(thread) {
    expect_u32(FB[0u32], 10);
    expect_u32(FB[5u32], 60);
    expect_u32(FB_LEN, 6);
    expect_u32(STRIDE_LEN, 3);
    expect_u32(PAIR.a + PAIR.b, 13);

    var local: [u32; FB_LEN] = [0u32, 1u32, 2u32, 3u32, 4u32, 5u32];
    expect_u32(len(local), 6);

    const v: view u32 = view(FB);
    expect_u32(len(v), 6);
    expect_u32(v[2u32], 30);

    const s: view u32 stride 2 = view(FB, stride 2);
    expect_u32(len(s), 3);
    expect_u32(s[2u32], 50);

    const r: ring u32 = ring(FB, 4u32, len(FB));
    expect_u32(len(r), 6);
    expect_u32(r[1u32], 60);

    var bytes: [u8; 2] = [0u8, 0u8];
    const bits_view: bits = bits(bytes);
    expect_u32(len(bits_view), 16);

    done();
}

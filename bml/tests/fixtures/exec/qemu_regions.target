# QEMU stm32vldiscovery target with a mem-block layout, for region placement
# tests. The 20K SRAM QEMU backs at 0x20000000 is split into a working RAM
# block (sram, holds .data/.bss/.stack) and a separate dma_pool block at
# 0x20004000 that a region is placed in -- proving `in <region>` lands a static
# at its mem block's address, distinct from ordinary statics.
arch = armv7m
cpu = cortex-m3
priority_bits = 4
has_bitband = true
flash_base = 0x08000000
flash_size = 64K
ram_base = 0x20000000
ram_size = 20K
vector_table_offset = 0x08000000

[mem.flash]
base = 0x08000000
size = 64K

[mem.sram]
base = 0x20000000
size = 16K

[mem.dma_pool]
base = 0x20004000
size = 0x1000

[agent.dma]
kind = dma
reach = dma_pool

[region.pool]
mem = dma_pool
agents = dma

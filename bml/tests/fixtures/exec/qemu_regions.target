# QEMU stm32vldiscovery target with a mem-block layout, for region placement
# tests. QEMU's stm32vldiscovery backs exactly 8K of SRAM at 0x20000000
# (verified with `info mtree`; the previous claim of 20K let the round-trip
# half of the fixture write to unmapped memory and hang -- masked until the
# reset-time ECC scrub walked the whole block). It is split into a working
# RAM block (sram, holds .data/.bss/.stack) and a separate dma_pool block at
# 0x20001800 that a region is placed in -- proving `in <region>` lands a
# static at its mem block's address, distinct from ordinary statics.
arch = armv7m
cpu = cortex-m3
priority_bits = 4
has_bitband = true
flash_base = 0x08000000
flash_size = 64K
ram_base = 0x20000000
ram_size = 8K
vector_table_offset = 0x08000000

[mem.flash]
base = 0x08000000
size = 64K

[mem.sram]
base = 0x20000000
size = 6K

[mem.dma_pool]
base = 0x20001800
size = 0x800

[agent.dma]
kind = dma
reach = dma_pool

[region.pool]
mem = dma_pool
agents = dma

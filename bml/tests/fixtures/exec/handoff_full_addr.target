# Handoff register write exec test. Peripheral lives at 0x20001000 -- in the low
# 8K SRAM above the 4K the linker uses for .data/.bss/.stack, so volatile MMIO
# writes round-trip through RAM and can be read back.
arch = armv7m
cpu = cortex-m3
priority_bits = 4
has_bitband = true
flash_base = 0x08000000
flash_size = 64K
ram_base = 0x20000000
ram_size = 4K
vector_table_offset = 0x08000000

[agent.fakedma]
kind = dma
handoff = FakeDma.PTRREG

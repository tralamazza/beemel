// A reclaim guarded by a completion-predicate helper (`if done() { reclaim }`)
// is accepted: `done` returns the agent's completion flag, so the guard is
// recognized inter-procedurally (B broadening).
peripheral DMAC at 0x40020000 {
    reg SR offset 0x00 {
        field DONE: b1 bit[0]
    }
}

var BUF: [u8; 32] in pool;

fn done() -> b1 {
    return DMAC.SR.DONE;
}

fn read_done(i: u32) -> u32 {
    if done() {
        const v = reclaim(BUF);
        return v[i] as u32;
    }
    return 0;
}

fn main() @context(thread) {
    var x: u32 = read_done(0);
}

// Indexing a mutable view borrows it; it does not move it. Two index reads of a
// `view mut` are both valid (regression: index-read used to consume the view,
// which made read loops over a mutable view impossible).
fn main() @context(thread) {
    var buf: [u32; 4] = [1u32, 2u32, 3u32, 4u32];
    var v: view mut u32 = view(buf);
    var a: u32 = v[0u32];
    var b: u32 = v[1u32];
}

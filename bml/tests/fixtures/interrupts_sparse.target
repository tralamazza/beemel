# A complete-style [interrupts] dictionary: several NVIC lines declared, spread
# out to a high slot (SPI4 = 84). A program that handles only a LOW line must
# size its vector table to that line, not to the highest DECLARED slot -- an
# unhandled (here, trailing) entry costs nothing. Regression target for the
# "[interrupts] is physics, footprint follows usage" rule.
arch = armv7em
priority_bits = 4

vector_table_offset = 0x08000000
data_block = ram
[interrupts]
TIM2 = 28
USART1 = 37
USART6 = 71
SPI4 = 84

[mem.flash]
base = 0x08000000
size = 256K

[mem.ram]
base = 0x20000000
size = 64K

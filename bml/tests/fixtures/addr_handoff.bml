// In-memory handoff: a buffer pointer written into an `addr in R` descriptor
// field. The buffer is in dma_shared (the region the field constrains to), the
// address flows through a helper, and IKOS discharges the obligation. Models
// the ETH descriptor word-0 buffer pointer. See doc/regions-agents-plan.md.
struct RxDesc @repr(packed) {
    buf1: addr in dma_shared,
    flags: u32,
}

var BUF: [u32; 128] @align(32) in dma_shared;
var RX: [RxDesc; 2] @align(32) in dma_shared;

fn buf_addr() -> u32 {
    return &BUF as u32;
}

fn main() @context(thread) {
    RX[0].buf1 = buf_addr();
    RX[0].flags = 1;
}

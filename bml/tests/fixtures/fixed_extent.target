# A fixed-block engine (EasyDMA style): no count register, the channel
# walks exactly 48 bytes from the delivered pointer (extent = 48).
arch = armv6m
cpu = cortex-m0
priority_bits = 2
vector_table_offset = 0x00000000
data_block = ram

[mem.flash]
base = 0x00000000
size = 256K

[mem.ram]
base = 0x20000000
size = 15K

[mem.ecb_ram]
base = 0x20003C00
size = 1K

[agent.ecb]
kind = dma
reach = ecb_ram
bus = 0x20000000..0x20004000
handoff = ECB.ECBDATAPTR
completes_by = ECB.EVENTS_ENDECB.READY
extent = 48

[region.ecb_buf]
mem = ecb_ram
agents = ecb

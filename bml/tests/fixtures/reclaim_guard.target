arch = armv7em
cpu = cortex-m7
vector_table_offset = 0x08000000
data_block = sram

[mem.flash]
base = 0x08000000
size = 256K

[mem.sram]
base = 0x20000000
size = 64K

[mem.dma_pool]
base = 0x30000000
size = 4K

# The agent declares its transfer-complete flag, which activates the
# sound-reclaim guard (E611).
[agent.dmac]
kind = dma
reach = dma_pool
completes_by = DMAC.SR.DONE

[region.pool]
mem = dma_pool
agents = dmac

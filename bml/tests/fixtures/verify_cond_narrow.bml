// Path-sensitive conditional narrowing: an unknown index `i` is bounded
// by an `if` check before the array access. IKOS must prove `i < 4` on
// the taken branch so `buf[i]` is in bounds.
fn lookup(i: u32) @context(thread) {
    var buf: [u32; 4] = [1u32, 2u32, 3u32, 4u32];
    if i < 4u32 {
        var x: u32 = buf[i];
    }
}

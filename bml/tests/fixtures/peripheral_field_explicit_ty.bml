// Test: explicit type annotations on bit fields
peripheral GPIOA at 0x40020000 {
    reg ODR offset 0x14 {
        // explicit b1 (same as implicit for bit[N])
        field ODR3: b1 bit[3]
        // override: single bit as u32
        field ODR0: u32 bit[0]
        // explicit u32 (same as implicit for bit[L..H])
        field ODR4: u32 bit[4..5]
    }
}

fn main() @context(thread) {
    var a: b1 = GPIOA.ODR.ODR3;
    var b: u32 = GPIOA.ODR.ODR0;
    var c: u32 = GPIOA.ODR.ODR4;
    GPIOA.ODR.ODR3 = true;
    GPIOA.ODR.ODR0 = 1;
    GPIOA.ODR.ODR4 = 3;
}

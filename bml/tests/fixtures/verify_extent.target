# verify_handoff.target plus an extent declaration: XFERCNT.COUNT counts
# words (x4 bytes). Writing it asserts count*4 <= sizeof(the buffer last
# delivered to DESCADDR).
arch = armv7em
cpu = cortex-m7
data_block = sram

[mem.flash]
base = 0x08000000
size = 1M

[mem.sram]
base = 0x20000000
size = 128K

[mem.sram1]
base = 0x30000000
size = 16K

[agent.mydma]
kind = dma
reach = sram1
handoff = MyDma.DESCADDR align 4
extent = MyDma.XFERCNT.COUNT x4

[region.dma_shared]
mem = sram1
agents = mydma

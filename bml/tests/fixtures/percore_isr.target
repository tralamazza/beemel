# Two cores + a labeled IRQ: the ISR's core is derived from where its NVIC
# ISER bit is written (the NVIC is banked per core).
arch = armv7em
cpu = cortex-m7

vector_table_offset = 0x08000000
data_block = ram
[agent.core1]
kind = cpu
reach = *
entry = side_main

[interrupts]
TICKER = 5

[mem.flash]
base = 0x08000000
size = 256K

[mem.ram]
base = 0x20000000
size = 64K

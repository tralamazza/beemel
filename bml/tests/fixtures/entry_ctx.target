# A second cpu core with a declared entry: the entry may carry a concrete
# @context, and taking its address (the launch handshake) is exempt from
# E408.
arch = armv7em
cpu = cortex-m7

vector_table_offset = 0x08000000
data_block = ram
[agent.core1]
kind = cpu
reach = *
entry = core_main

[mem.flash]
base = 0x08000000
size = 256K

[mem.ram]
base = 0x20000000
size = 64K

// Bounded spin loop with an MMIO read in the guard -- the spin-loop V130
// class. Conditions lower as short-circuit BRANCH TREES (no materialized
// boolean, no phi): each conjunct is a same-block decision the verifier
// refines through, so `spin + 1` proves and so does the post-loop bound.
// Under the old eager `and i1` lowering IKOS could not refine the counter
// bound through the conjunction when the other operand came from a
// hardware load -- and a phi-based short-circuit form fails the same way
// (per-edge phi reasoning). The tree encodes the facts in the CFG itself.
peripheral P at 0x40000000 {
    reg SR offset 0x0 {
        field RDY: b1 bit[0]
    }
}

const TIMEOUT: u32 = 1000000;

fn main() @context(thread) {
    var spin: u32 = 0;
    while spin < TIMEOUT && !P.SR.RDY {
        spin = spin + 1;
    }
    assert(spin <= TIMEOUT);
}

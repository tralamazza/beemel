// Bare @shared with two ISR accessors: derived ceiling = min(1, 3) = 1. The
// priority-3 ISR can be preempted by the priority-1 one, so its access gets a
// critical section (BASEPRI to ceiling 1; the only mask source here -- no
// thread code).
var counter: u32 @shared;

fn fast() @isr(priority = 1) {
    var x: u32 = counter;
    counter = x + 1;
}

fn slow() @isr(priority = 3) {
    var x: u32 = counter;
    counter = x + 1;
}

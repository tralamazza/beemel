# Transitive-reach (E608) target. Two regions in two mem blocks. The DMA agent
# reaches sram1 (where the descriptor lives) but NOT dtcm. A descriptor field
# pointing into the dtcm region is the footgun E608 catches: validate_regions
# only checks a region against its *listed* agents, so a CPU-owned dtcm region
# validates fine -- the danger only appears when a DMA-walked descriptor's field
# points there.
arch = armv7em
cpu = cortex-m7

data_block = dtcm
[mem.flash]
base = 0x08000000
size = 1M

[mem.dtcm]
base = 0x20000000
size = 128K

[mem.sram1]
base = 0x30000000
size = 16K

[agent.cpu]
kind = cpu
reach = *

[agent.mydma]
kind = dma
reach = sram1
handoff = MyDma.DESCADDR align 4

[region.desc_region]
mem = sram1
agents = mydma

[region.dtcm_region]
mem = dtcm
agents = cpu

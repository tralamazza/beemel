// The index-borrow fix is shared across view kinds: two index reads of a
// `ring mut` are both valid (no consume).
fn main() @context(thread) {
    var buf: [u32; 8] = [0u32, 1u32, 2u32, 3u32, 4u32, 5u32, 6u32, 7u32];
    var r: ring mut u32 = ring(buf, 0u32, 8u32);
    var a: u32 = r[0u32];
    var b: u32 = r[1u32];
}

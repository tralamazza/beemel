// Views can be built over storage-wrapped arrays whose storage class carries no
// ceiling protocol (@dma/@external/@exclusive): the wrapper is unwrapped at
// construction and kept out of the view's type identity. (@shared is rejected
// separately; view access would bypass its critical-section protection.)
var DBUF: [u32; 4] @dma = [10u32, 20u32, 30u32, 40u32];
var EBUF: [u8; 8] @external = [0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8];

fn main() @context(thread) {
    const v: view u32 = view(DBUF);
    var a: u32 = v[1u32];
    var r: ring mut u32 = ring(DBUF, 0u32, 4u32);
    r[0u32] = 99u32;
    var b: bits mut = bits(EBUF);
    b[5u32] = true;
}

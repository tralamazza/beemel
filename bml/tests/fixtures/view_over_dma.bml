// Agent-shared (@dma/@external) memory is reached through the view family with
// the wrapper unwrapped at construction. A contiguous view needs the explicit
// `reclaim(x)` (plain `view(x)` over agent-shared is rejected, E335 -- the agent
// may still own it). ring/bits are not yet tightened. (@shared is rejected
// separately; view access would bypass its critical-section protection.)
var DBUF: [u32; 4] @dma = [10u32, 20u32, 30u32, 40u32];
var EBUF: [u8; 8] @external = [0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8];

fn main() @context(thread) {
    const v: view u32 = reclaim(DBUF);
    var a: u32 = v[1u32];
    var r: ring mut u32 = ring(DBUF, 0u32, 4u32);
    r[0u32] = 99u32;
    var b: bits mut = bits(EBUF);
    b[5u32] = true;
}

// comptime recursion unrolls (Phase 3 slice 2b): `accumulate(0)` specializes
// accumulate$0..$4; in each, the comptime if folds with `i` bound and the
// recursive arg `i + 1` evaluates, so the call chain stops at i == 4 (the base
// case `i < 4` is false). No accumulate$5 is ever emitted. See doc/comptime.md.
fn accumulate(comptime i: u32) -> u32 {
    comptime if i < 4 {
        return i + accumulate(i + 1);
    }
    return 0;
}

export fn main() @context(thread) {
    var r: u32 = accumulate(0);
}

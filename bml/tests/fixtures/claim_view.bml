// `claim X { ... }`: the masked ownership window over a @shared static (the
// CPU-side reclaim). Inside, X is its inner type: views and index-reads are
// allowed, and the whole block runs under ONE cpsid/cpsie pair (per-access
// critical sections inside are suppressed -- the mask covers them).
var BUF: [u8; 8] @shared;

fn tick() @isr(priority = 2) {
    BUF[0] = 1;
}

fn main() @context(thread) {
    claim BUF {
        const v = view(BUF);
        var x: u32 = v[0] as u32;
        BUF[1] = x as u8;
    }
}

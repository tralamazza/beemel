// Hand-written equivalent of peripheral_type_ok.bml: two full peripherals with
// identical register layouts. The peripheral_type form must lower to byte-
// identical IR -- it is pure parser desugar (instances clone the template regs).
peripheral GPIOA at 0x40020000 {
    reg MODER offset 0x00 { field MODE0: u32 bit[0..1] }
    reg ODR offset 0x14 { field ODR0: b1 bit[0] }
}

peripheral GPIOB at 0x40020400 {
    reg MODER offset 0x00 { field MODE0: u32 bit[0..1] }
    reg ODR offset 0x14 { field ODR0: b1 bit[0] }
}

export fn main() @context(thread) {
    GPIOA.MODER.MODE0 = 1;
    GPIOB.ODR.ODR0 = true;
}

// Ring view over a local array: logical index i maps to physical (head+i) %
// capacity. Capacity is the compile-known array length, so the verifier proves
// the access (the urem bounds the physical index into the backing array).
fn main() @context(thread) {
    var buf: [u32; 8] = [0u32, 1u32, 2u32, 3u32, 4u32, 5u32, 6u32, 7u32];
    val r: ring u32 = ring(buf, 0u32, 8u32);
    var x: u32 = r[2u32];
}

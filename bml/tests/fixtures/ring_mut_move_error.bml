// A mutable ring is Move: passing it consumes it, so reuse is a use-after-move.
fn reads(r: ring u32) -> u32 {
    return r[0u32];
}
fn main() @context(thread) {
    var buf: [u32; 8] = [0u32, 1u32, 2u32, 3u32, 4u32, 5u32, 6u32, 7u32];
    var r: ring mut u32 = ring(buf, 0u32, 8u32);
    var a: u32 = reads(r);   // moves r
    var b: u32 = reads(r);   // E304
}

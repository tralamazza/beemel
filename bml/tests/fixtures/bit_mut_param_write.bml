// Writing through a `bits mut` parameter (an immutable binding). Regression for
// the BitView case of the binding-mutability exemption (E309 must not fire).
fn fill(b: bits mut) @context(thread) {
    b[1u32] = true;
}
fn main() @context(thread) {
    var buf: [u8; 4] = [0u8, 0u8, 0u8, 0u8];
    var b: bits mut = bits(buf);
    fill(b);
}

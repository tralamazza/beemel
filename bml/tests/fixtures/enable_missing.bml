// Agent enable missing: the handoff register is programmed but the clock gate
// Clk.CR.MYDMAEN is never set -> the writes hit a gated peripheral (E609).
peripheral Clk at 0x40021000 {
    reg CR offset 0x00 {
        field MYDMAEN: b1 bit[0]
    }
}
peripheral MyDma at 0x40030000 {
    reg DESCADDR offset 0x00 {
        field PTR: u32 bit[2..31]
    }
}
owns MyDma;
fn main() @context(thread) {
    MyDma.DESCADDR.PTR = 0x20001000;
}

// Regression fixture for two verify-pipeline bugs:
//
// 1. Struct debug metadata: the DICompositeType `elements:` list was emitted
//    with doubled braces (`!{{...}}`), which LLVM's IR parser rejects -- any
//    struct-containing program made `bml verify` fail in `opt`.
// 2. Report parsing: IKOS emits `"operands": null` on unreachable report
//    entries (the dead branch below); the JSON parser must accept the null.
//
// A passing assert keeps the fixture finding-free so the run exits 0.
struct Desc {
    w0: u32,
    w3: u32,
}

fn main() @context(thread) {
    var d = Desc { w0: 1, w3: 2 };
    var x: u32 = d.w0;
    assume(x == 1);
    if x != 1 {
        // Provably dead: IKOS reports it as unreachable with null operands.
        x = 99;
    }
    assert(d.w3 == 2);
}

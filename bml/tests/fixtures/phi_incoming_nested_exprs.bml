fn main() @context(thread) {
    var buf: [u32; 2] = [10u32, 20u32];

    var if_value: u32 = if true {
        val v: view u32 = view(&buf[0], 2u32);
        v[0u32]
    } else {
        0u32
    };

    var match_value: u32 = match 0u32 {
        0u32 {
            val v: view u32 = view(&buf[0], 2u32);
            v[1u32]
        }
        _ {
            0u32
        }
    };
}

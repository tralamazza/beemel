// Boolean types: b1 literals, if/while conditions, logical not
fn main() @context(thread) {
    const t: u32 = 42;
    const f: u32 = 0;

    if true {
        var x: u32 = 1;
    }

    while true {
        if false {
            var y: u32 = 2;
        }
        break;
    }

    const cond = true;
    const neg = !cond;
    const chained = cond || false;
    const both = cond && true;
}

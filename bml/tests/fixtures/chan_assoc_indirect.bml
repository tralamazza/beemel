// Positive (conservative fallback): the delivery goes through a helper,
// so no channel association is visible -- the region union applies and
// either flag is accepted, as before.
peripheral DMAC at 0x40020000 {
    reg SR offset 0x00 {
        field DONE_A: b1 bit[0]
        field DONE_B: b1 bit[1]
    }
    reg A_ADDR offset 0x04 {
        field A: u32 bit[0..31]
    }
    reg B_ADDR offset 0x08 {
        field A: u32 bit[0..31]
    }
}

owns DMAC;

var BUF: [u8; 32] in pool;
var X: u32;

fn buf_addr() -> u32 {
    return &BUF as u32;
}

fn main() @context(thread) {
    DMAC.A_ADDR = buf_addr();
    if DMAC.SR.DONE_B {
        const v = reclaim(BUF);
        X = v[0] as u32;
    }
}

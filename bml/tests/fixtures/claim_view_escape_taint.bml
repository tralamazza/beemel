// E616 through a hop: the view is first bound INSIDE the window (legal),
// then the inside binding is copied to an outside one -- same escape, one
// indirection deeper (lexical taint).
var BUF: [u8; 8] @shared;
var OTHER: [u8; 8];

fn tick() @isr(priority = 2) {
    BUF[0] = 1;
}

fn main() @context(thread) {
    var v = view(OTHER);
    claim BUF {
        const t = view(BUF);
        v = t;
    }
    var x: u32 = v[0] as u32;
}

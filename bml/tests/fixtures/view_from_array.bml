// Array-to-view sugar: `view(arr)` derives both element type and a
// compile-known length from the array. Read intra-procedurally and via a
// helper; the verifier proves both bounds.
fn sum2(v: view u32) -> u32 {
    var a: u32 = v[0u32];
    var b: u32 = v[1u32];
    return a + b;
}

fn main() @context(thread) {
    var buf: [u32; 4] = [10u32, 20u32, 30u32, 40u32];
    val v: view u32 = view(buf);
    var x: u32 = v[2u32];
    var s: u32 = sum2(view(buf));
}

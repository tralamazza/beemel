// Taking the address of a Move-typed local borrows it; it must not consume the
// value. Both `&x` and `&mut x` are non-consuming, so `x` stays usable after.
static dbuf: u32 @dma;

fn main() @context(thread) {
    var x = dbuf;            // Move-typed local
    var p: *u32 = &x;        // const borrow: no move
    var q: *mut u32 = &mut x; // mut borrow: no move
    var a = x;               // ok: addr-of did not consume x
}

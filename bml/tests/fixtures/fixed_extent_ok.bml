// Positive: the delivered buffer is exactly the fixed 48-byte block.
peripheral ECB at 0x4000E000 {
    reg TASKS_STARTECB offset 0x000 {
        field START: b1 bit[0]
    }
    reg EVENTS_ENDECB offset 0x100 {
        field READY: b1 bit[0]
    }
    reg ECBDATAPTR offset 0x504 {
        field PTR: u32 bit[0..31]
    }
}

owns ECB;

var BLOCK: [u8; 48] in ecb_buf;
var X: u32;

fn main() @context(thread) {
    ECB.ECBDATAPTR = &BLOCK as u32;
    ECB.TASKS_STARTECB.START = true;
    while !ECB.EVENTS_ENDECB.READY {}
    const v = reclaim(BLOCK);
    X = v[32] as u32;
}

// Compared guard, positive form: `== true` establishes the flag.
peripheral DMAC at 0x40020000 {
    reg SR offset 0x00 {
        field DONE: b1 bit[0]
    }
    reg ADDR offset 0x04 {
        field A: u32 bit[0..31]
    }
}

owns DMAC;

var BUF: [u8; 32] in pool;
var X: u32;

fn main() @context(thread) {
    if DMAC.SR.DONE == true {
        const v = reclaim(BUF);
        X = v[0] as u32;
    }
}

// Readonly strided view: every 2nd u32 of an 8-element array (logical length
// N/K = 4). Intra-procedural, so the verifier sees the backing allocation; the
// index lowers to a typed GEP with a constant `* K` multiplier.
fn main() @context(thread) {
    var buf: [u32; 8] = [0u32, 1u32, 2u32, 3u32, 4u32, 5u32, 6u32, 7u32];
    val v: view u32 stride 2 = view(buf, stride 2);
    var x: u32 = v[3u32];
}

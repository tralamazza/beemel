// Binary comparison operators
fn main() @context(thread) {
    var a: u32 = 10;
    var b: u32 = 20;

    if a == b {
        var x: u32 = 1;
    }
    if a != b {
        var x: u32 = 2;
    }
    if a < b {
        var x: u32 = 3;
    }
    if a > b {
        var x: u32 = 4;
    }
    if a <= b {
        var x: u32 = 5;
    }
    if a >= b {
        var x: u32 = 6;
    }
}

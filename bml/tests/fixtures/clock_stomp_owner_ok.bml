// The module that owns the agent may gate its own clock (a deinit/reset
// sequence) -> no E610. Same disabling write as clock_stomp.bml, but from the
// owner.
peripheral Clk at 0x40021000 {
    reg CR offset 0x00 {
        field MYDMAEN: b1 bit[0]
    }
}
peripheral MyDma at 0x40030000 {
    reg DESCADDR offset 0x00 {
        field PTR: u32 bit[2..31]
    }
}

owns MyDma;

fn main() @context(thread) {
    Clk.CR.MYDMAEN = true;
    MyDma.DESCADDR = 0x20001000;
    Clk.CR.MYDMAEN = false;
}

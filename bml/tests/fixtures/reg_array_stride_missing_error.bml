// A register array `reg NAME[N]` with no `stride S` is rejected (E116): the
// stride is required to address the slots.
peripheral_type FIFO {
    reg MEM[4] offset 0x10 { field MEM: u32 bit[0..15] writeonly }
}
peripheral FIFO0: FIFO at 0x40000000;

export fn main() @context(thread) {
    FIFO0.MEM = 1u32;
}

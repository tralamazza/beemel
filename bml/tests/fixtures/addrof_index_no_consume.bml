// Taking the address of a view *element* borrows the view through the place
// chain; it must not consume the view. Exercises the Index arm of
// read_place_type via the `&mut`/`&` operand path.
fn take_mut(p: *mut u32) {}
fn take_ref(p: *u32) {}
fn main() @context(thread) {
    var buf: [u32; 4] = [1u32, 2u32, 3u32, 4u32];
    var v: view mut u32 = view(buf);
    take_mut(&mut v[0u32]);   // borrow element: no move
    take_ref(&v[1u32]);       // borrow element: no move
    var a: u32 = v[2u32];     // ok: addr-of did not consume v
}

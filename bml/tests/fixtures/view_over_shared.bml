// A view over @shared memory is rejected (E405). The @shared ceiling protocol is
// enforced by a critical section around direct static access; a view loads/stores
// through the descriptor pointer with no static name, so it gets no critical
// section and would be a silent unprotected race.
var SBUF: [u8; 4] @shared(ceiling = 1) = [0u8, 0u8, 0u8, 0u8];

fn main() @context(thread) {
    var b: bits mut = bits(SBUF);
    b[0u32] = true;
}

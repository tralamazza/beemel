// Test: multi-bit field range read and RMW write
peripheral GPIOA at 0x40020000 {
    reg MODER offset 0x00 {
        field MODER0: u32 bit[0..1]
        field MODER1: u32 bit[2..3]
    }
    reg ODR offset 0x14 {
        field ODR0: b1 bit[0]
    }
}

fn main() @context(thread) {
    var mode: u32 = GPIOA.MODER.MODER0;
    GPIOA.MODER.MODER1 = 3;
}

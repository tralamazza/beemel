# reclaim_guard.target plus a handoff register, so a write to DMAC.ADDR is a
# RELEASE (hands the buffer back to the agent) for the truncation checks
# (E611 after a release, E616 view use after a release).
arch = armv7em
cpu = cortex-m7
vector_table_offset = 0x08000000
data_block = sram

[mem.flash]
base = 0x08000000
size = 256K

[mem.sram]
base = 0x20000000
size = 64K

[mem.dma_pool]
base = 0x30000000
size = 4K

[agent.dmac]
kind = dma
reach = dma_pool
completes_by = DMAC.SR.DONE
handoff = DMAC.ADDR

[region.pool]
mem = dma_pool
agents = dmac

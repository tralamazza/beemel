# Cortex-M3-style target with bit-banding (the default): single-bit field
# writes go through the 0x42 alias region, which the verify hwaddrs
# whitelist must cover.
arch = armv7m
cpu = cortex-m3

vector_table_offset = 0x08000000
data_block = ram

[mem.flash]
base = 0x08000000
size = 256K

[mem.ram]
base = 0x20000000
size = 64K

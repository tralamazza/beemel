// Transitive reach (E608): the descriptor lives in desc_region (sram1, which
// mydma reaches), but its `buf1` field is `addr in dtcm_region` (DTCM), which
// mydma cannot reach. Delivering `&RX` to mydma's handoff hands the agent a
// descriptor whose buffer pointer is outside its reach -> error.
peripheral MyDma at 0x40030000 {
    reg DESCADDR offset 0x00 {
        field PTR: u32 bit[0..31]
    }
}

struct RxDesc @repr(packed) {
    buf1: addr in dtcm_region,
    flags: u32,
}

var RX: [RxDesc; 2] @align(32) in desc_region;

owns MyDma;

fn main() @context(thread) {
    MyDma.DESCADDR = &RX as u32;
}

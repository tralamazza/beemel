// Same as view_mut_param_write but for a `ring mut` parameter. Regression for
// the RingView case of the binding-mutability exemption.
fn fill(r: ring mut u32) @context(thread) {
    r[1u32] = 7u32;
}
fn main() @context(thread) {
    var buf: [u32; 8] = [0u32,1u32,2u32,3u32,4u32,5u32,6u32,7u32];
    var r: ring mut u32 = ring(buf, 0u32, 8u32);
    fill(r);
}

# Inverted-polarity gate: `!` on enabled_by means CLEAR-to-enable (the RP2350
# RESETS idiom -- the bit is held high at boot and software clears it).
arch = armv7em
cpu = cortex-m7

[mem.flash]
base = 0x08000000
size = 1M

[mem.sram]
base = 0x20000000
size = 128K

[agent.mydma]
kind = dma
reach = sram
handoff = MyDma.DESCADDR
enabled_by = !Rst.CR.MYDMARST

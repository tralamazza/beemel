// Regression (independent review of T1): a comptime function using `sizeof` of a
// composite (`[Foo; 4]`) must NOT silently mis-size an array. Pre-resolution the
// struct layout is unknown, so `sizeof` would compute the wrong value (the
// interpreter ran with an empty symbol table and `element_size`'s catch-all gives
// 4 bytes per unresolved component -> an under-sized array, a silent miscompile).
// The sizing must be rejected (E414) instead -- sizeof-based sizes are an
// out-of-scope boundary of comptime array sizing (the value still folds for
// non-sizing uses post-resolution).
struct Foo @repr(C) { a: u32, b: u32 }

fn elems() -> u32 {
    return sizeof([Foo; 4]);
}

const N: u32 = elems();
const A: [u8; N] = [0u8; N];

fn main() @context(thread) {
    var x: u8 = A[0];
}

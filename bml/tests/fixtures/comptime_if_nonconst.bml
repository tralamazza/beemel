// A `comptime if` condition that is structurally const but does NOT evaluate
// (here a division by zero) is rejected cleanly at check time (E411) -- via the
// literal-zero-divisor guard / eval-at-check -- rather than panicking codegen or
// silently falling through. See doc/comptime.md.
fn pick() -> u32 {
    comptime if 5 / 0 == 1 {
        return 1;
    }
    return 2;
}

export fn main() @context(thread) {
    var r: u32 = pick();
}

// Mutable strided view: write every 2nd u32. The stride comes from a `const`,
// so constfold reduces it to a literal before the checker/IR see it. The write
// lowers to the same typed GEP with a `* K` multiplier as the read.
const K: u32 = 2;
fn main() @context(thread) {
    var buf: [u32; 8] = [0u32, 1u32, 2u32, 3u32, 4u32, 5u32, 6u32, 7u32];
    var v: view mut u32 stride K = view(buf, stride K);
    v[3u32] = 99u32;
}

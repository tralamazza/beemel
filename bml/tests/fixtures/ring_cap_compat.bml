// A ring inferred from a power-of-two array carries a compile-time capacity
// hint (`Some(8)`), but a `ring u32` parameter carries none (`None`). Passing
// the former where the latter is expected must type-check: the capacity hint is
// a value-level optimization fact, not part of type identity. The un-annotated
// `val r` is what keeps the hint on r's type at the call site (an annotation
// would erase it), so this genuinely exercises the Some -> None compatibility.
fn first(r: ring u32) -> u32 @context(thread) {
    return r[0u32];
}
fn main() @context(thread) {
    var buf: [u32; 8] = [0u32, 1u32, 2u32, 3u32, 4u32, 5u32, 6u32, 7u32];
    val r = ring(buf, 0u32, 8u32);
    var x: u32 = first(r);
}

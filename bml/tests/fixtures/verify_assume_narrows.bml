// Real range-narrowing test: divisor is an unknown function parameter.
// After mem2reg, the assume on the SSA value narrows its range to non-zero,
// so the subsequent division is provably safe (no V120 finding).
fn divide(b: u32) @context(thread) {
    var a: u32 = 10;
    assume(b != 0u32);
    var c: u32 = a / b;
}

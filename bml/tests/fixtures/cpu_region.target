# Control target for derived-Move: a region whose only agent is the CPU. No
# concurrently-mutating (DMA/external) agent, so an array placed here stays plain
# `Array` -- normal, freely-indexable memory.
arch = armv7em
cpu = cortex-m7

[mem.flash]
base = 0x08000000
size = 1M

[mem.sram1]
base = 0x20000000
size = 128K

[agent.cpu]
kind = cpu
reach = *

[region.cpu_region]
mem = sram1
agents = cpu

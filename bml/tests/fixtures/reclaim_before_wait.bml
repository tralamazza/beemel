// Ordering matters: the busy-wait establishes the flag only AFTER the loop,
// so a reclaim placed before it is unguarded (E611) -- the agent may still be
// writing when the view is taken.
peripheral DMAC at 0x40020000 {
    reg SR offset 0x00 {
        field DONE: b1 bit[0]
    }
}

var BUF: [u8; 32] in pool;

fn read_done(i: u32) -> u32 {
    const v = reclaim(BUF);
    while !DMAC.SR.DONE {}
    return v[i] as u32;
}

fn main() @context(thread) {
    var x: u32 = read_done(0);
}

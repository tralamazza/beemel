// Test: single-bit field RMW write to peripheral register
peripheral GPIOA at 0x40020000 {
    reg MODER offset 0x00 {
        field MODER0: u32 bit[0..1]
    }
    reg ODR offset 0x14 {
        field ODR0: b1 bit[0]
        field ODR3: b1 bit[3]
    }
}

fn main() @context(thread) {
    GPIOA.ODR.ODR3 = 1;
    GPIOA.ODR.ODR0 = 0;
}

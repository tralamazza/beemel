// A write to a register holding a declared clock gate (enabled_by) is
// followed by a derived volatile read-back: the first peripheral write
// issued while the enable is still propagating is silently dropped by the
// bus (observed on the H723 -- the TIM2 PSC write vanished). Pairs with
// enable.target (gate Clk.CR.MYDMAEN).
peripheral Clk at 0x40021000 {
    reg CR offset 0x00 {
        field MYDMAEN: b1 bit[0]
    }
}
peripheral MyDma at 0x40030000 {
    reg DESCADDR offset 0x00 {
        field PTR: u32 bit[2..31]
    }
}
owns MyDma;
fn main() @context(thread) {
    Clk.CR.MYDMAEN = true;
    MyDma.DESCADDR = 0x20001000;
}

// `comptime if` over a `comptime` parameter (Phase 3 slice 2a): the param's
// value is bound per specialization, so the condition folds there. classify$0
// emits only the `0` branch (100); classify$1 only the else branch (200).
fn classify(comptime mode: u32) -> u32 {
    comptime if mode == 0 {
        return 100;
    } else {
        return 200;
    }
}

export fn main() @context(thread) {
    var a: u32 = classify(0);
    var b: u32 = classify(1);
}

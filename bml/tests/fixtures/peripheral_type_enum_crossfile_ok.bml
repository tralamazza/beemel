// Cross-file template whose inline enum is qualified by the template's module:
// the variant is referenced via the import alias (`ip.SizeSel@Word`). Exercises
// the qualify interaction (template field types rewritten to the qualified enum
// name, then cloned into the instance here).
import peripheral_type_enum_ip as ip;

peripheral DMA0: Dma at 0x40030000;

export fn main() @context(thread) {
    DMA0.CTRL.SIZE = ip.SizeSel@Word;
}

// *mut T → *T implicit coercion in function calls and assignments
var buf: u8;

fn read_buf(p: *u8) {
    var x = *p;
}

fn main() @context(thread) {
    const p: *mut u8 = &mut buf;
    // Implicit coercion: *mut u8 → *u8 in function call
    read_buf(p);

    // Implicit coercion: *mut u8 → *u8 in var assignment
    var q: *u8 = p;

    // Explicit direction needs as cast
    var r: *mut u8 = q as *mut u8;
}

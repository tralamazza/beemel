// A peripheral_type handle has no address: borrowing it (`&u`) is rejected
// (E309). It is monomorphized away, so there is nothing to point at.
peripheral_type Usart { reg CR1 offset 0x00 { field UE: b1 bit[0] } }
peripheral USART1: Usart at 0x40011000;

fn f(u: Usart) { var p: *u8 = &u as *u8; }

export fn main() @context(thread) { f(USART1); }

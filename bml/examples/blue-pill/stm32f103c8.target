# STM32F103C8T6 (Blue Pill) -- project target.
#
# Chip physics (Cortex-M3, memory map for the C8's 64 KB flash / 20 KB RAM)
# come from the shipped lib/stm32f103/stm32f103.target, resolved via the lib
# search path (dev builds find the in-tree lib/ automatically; otherwise pass
# `--lib`). This blinky program uses no DMA agents and declares no regions, so
# the project layer is just the chip selection.
include = stm32f103/stm32f103.target

# BBC micro:bit V1 (nRF51822-QFAA)
# Cortex-M0, 256KB flash, 16KB RAM
arch = armv6m
cpu = cortex-m0
priority_bits = 2
has_bitband = false
has_fpu = false
has_mpu = false
vector_table_offset = 0x00000000

data_block = ram

[mem.flash]
base = 0x00000000
size = 256K

[mem.ram]
base = 0x20000000
size = 16K

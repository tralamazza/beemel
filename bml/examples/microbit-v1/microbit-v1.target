# BBC micro:bit V1 -- project target.
#
# The chip physics (memory map for the nRF51822-QFAA) live in the shipped
# library target `lib/nrf51/nrf51.target`, resolved via the lib search path
# (dev builds find the in-tree lib/ automatically; otherwise pass `--lib`).
# This blinky/scroll program uses no DMA agents and declares no regions, so the
# project layer is just the chip selection.
include = nrf51/nrf51.target

# RP2350 DMA -> PIO bridge -- board/project target.
include = rp2350/rp2350.target

# 4 MB QSPI flash (board physics).
[mem.flash]
base = 0x10000000
size = 4M

# Project claim: the DMA streams a buffer out of the dedicated sram8 bank into a
# PIO FIFO. reach is cross-checked against the chip's DMA bus windows at load.
[agent.dma]
reach = sram8, flash

[region.dma_buf]
mem = sram8
agents = dma

# Channel 0 is paired with the PIO0 TX0 FIFO. Both halves of the pairing are
# checked against the program: the transfer request (or the DMA over/underruns
# the FIFO, E651) and the endpoint address the write handoff is pointed at (or
# the DMA streams to the wrong place, E652).
[agent.dma.ch0]
dreq = DMA.CH0_CTRL_TRIG.TREQ_SEL = PIO0_TX0
endpoint = DMA.CH0_WRITE_ADDR = PIO0.TXF[0]

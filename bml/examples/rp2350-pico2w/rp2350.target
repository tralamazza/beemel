# RP2350 chip physics (base target) -- the cross-vendor falsification
# exercise: does the regions/agents vocabulary, grown on the STM32H723, hold
# for another vendor's silicon with no new keys? Transcribed from the RP2350
# datasheet (sections 2.1 bus fabric, 2.2 address map, 7 resets, 12.6 DMA).
#
# NOTE the chip has NO internal flash: the XIP window is chip physics, the
# flash SIZE is board physics. This file carries no [mem.flash]; the board
# target (pico2w.target) includes this file and adds it -- a three-layer
# chip/board/project split the include chain supports unchanged.
#
# FINDINGS from this transcription (recorded in doc/regions-agents-plan.md).
# Two of the three vocabulary gaps are now CLOSED by the `!` polarity marker:
# - CLOSED: `enabled_by = !RESETS.RESET.DMA` expresses CLEAR-to-enable
#   gating (reset value 1 = held in reset); E609 requires the clearing
#   write, E610 rejects a stranger re-asserting the reset.
# - CLOSED: `completes_by = !DMA.CH0_CTRL_TRIG.BUSY` expresses the busy-HIGH
#   flag; the native `while BUSY {}` wait-while-set idiom is an accepted
#   E611 guard (the raw INTR bit remains as the done-high alternative).
# - CLOSED: PMSAv8 MPU emission exists (MpuFlavor follows the core:
#   cortex-m33 -> RBAR/RLAR + MAIR attribute indirection, 32-byte
#   granularity instead of the PMSAv7 power-of-two shape). has_mpu = true;
#   the board target marks sram8 cacheable = false, generating one v8
#   region. (No data cache here, so the attribute is belt-and-braces; the
#   point is validating the v8 emission on real PMSAv8 silicon.)
arch = armv7em
cpu = cortex-m33
# SIO hardware spinlocks: 32 read-to-claim / write-to-release mutex
# registers. Chip physics backing the cross-core `claim` window.
spinlock_base = 0xD0000100
spinlock_count = 32
priority_bits = 4
has_fpu = true
has_bitband = false
has_mpu = true
# Code runs from the XIP window; the board target's flash block covers this.
vector_table_offset = 0x10000000
data_block = sram

# Minimum Arm IMAGE_DEF (datasheet 5.9.5.1), placed by the linker directly
# after the vector table -- inside the boot ROM's 4 kB flash scan window. No
# entry-point item, so the bootrom enters via the Cortex-M vector table at
# the image start (SP at +0, reset handler at +4), which is exactly the
# table the compiler generates.
[boot_block]
0xffffded3
0x10210142
0x000001ff
0x00000000
0xab123579

# Main system SRAM: 512 KB, striped on address bits 3:2 across banks 0-7
# (two 256 KB power domains; the striping is invisible to software layout).
[mem.sram]
base = 0x20000000
size = 512K

# SRAM8/9: 4 KB each, non-striped, directly after the striped region. Useful
# as dedicated per-purpose banks (no striping contention). sram8 hosts the
# DMA buffers (board target's dma_buf region) and is declared non-cacheable
# -> one generated PMSAv8 MPU region (the v8 emission validation; RP2350 has
# no data cache, so this is configuration truth rather than a coherence
# requirement).
[mem.sram8]
base = 0x20080000
size = 4K
cacheable = false

[mem.sram9]
base = 0x20081000
size = 4K

# The central DMA controller (16 channels; one agent -- channels share the
# controller's reach, like the H7 DMA streams). Datasheet 2.1: the AHB5
# crossbar gives the DMA read and write masters paths to ROM, XIP, SRAM, and
# the APB/AHB peripherals. NOT reachable: SIO (0xd0000000) and the M33
# private peripherals (0xe0000000) -- those are core-local, on dedicated
# per-processor paths, not crossbar downstream ports. That exclusion is the
# whole reach story on this chip (the opposite pole from the nRF52, whose
# EasyDMA cannot even read flash).
[agent.dma]
kind = dma
bus = 0x00000000..0x00008000, 0x10000000..0x20000000, 0x20000000..0x20082000, 0x40000000..0x60000000
# Channel 0 address handoffs: READ_ADDR is where the agent reads, WRITE_ADDR
# where it writes (full byte addresses, written verbatim -- same model as the
# H7 MDMA SAR/DAR).
handoff = DMA.CH0_READ_ADDR
handoff = DMA.CH0_WRITE_ADDR
# Raw per-channel completion bit (INTR, offset 0x400): set when the channel
# finishes a transfer sequence, readable with interrupts disabled. Activates
# the sound-reclaim guard (E611).
completes_by = DMA.INTR.CH0, !DMA.CH0_CTRL_TRIG.BUSY
# Clear-to-enable gating (`!` = inverted polarity): the DMA is held in reset
# at boot; software clears the bit to enable it.
enabled_by = !RESETS.RESET.DMA

# The second Cortex-M33. A full crossbar master -- a genuine cpu-kind agent,
# declared to probe the multi-core boundary the plan defers ("multi-core not
# designed here"): nothing checks core1's accesses today, this line only
# records that the sharer exists.
[agent.core1]
kind = cpu
cached = false
reach = *

# Raspberry Pi Pico 2 W -- board + project target.
#
# Layering: rp2350.target is chip physics; this file adds BOARD physics (the
# external QSPI flash -- the chip has none, so flash size is a board fact)
# and project policy (regions). Same include mechanism as the H723 split,
# stretched to three layers without new vocabulary.
include = rp2350.target

# 4 MB QSPI flash, memory-mapped through the XIP window.
[mem.flash]
base = 0x10000000
size = 4M

# Project claim: which blocks this program actually hands to the DMA. The
# chip's bus windows (rp2350.target) cross-check it at target load.
[agent.dma]
reach = sram8, flash

# DMA copy buffers live in the dedicated non-striped sram8 bank (declared
# non-cacheable in the chip target -> generated PMSAv8 MPU region).
[region.dma_buf]
mem = sram8
agents = dma

# Bind core1 to its entry: everything core1_main transitively mentions runs
# on core1, and the cross-core sharing check (E615) keeps the two cores'
# mutable statics partitioned.
[agent.core1]
entry = core1_main

# nRF51822 -- chip physics (third vendor, third agent shape).
#
# Nordic has NO central DMA controller: each capable peripheral is its own
# bus master walking a pointer the program hands it (EasyDMA style). The
# probe uses the simplest one, the AES ECB engine: ECBDATAPTR points at one
# FIXED 48-byte block (KEY[16] | CLEARTEXT[16] | CIPHERTEXT[16]); there is
# no count register, so the extent is the literal block size and the
# obligation moves to the delivery (E619: the buffer must be >= 48 bytes).
#
# Cortex-M0 facts this file pins: ARMv6-M, 2 priority bits (NVIC IPR is
# word-access-only -- the reset handler composes whole IPR words), no MPU,
# vector table at flash base.
arch = armv6m
cpu = cortex-m0
priority_bits = 2
vector_table_offset = 0x00000000
data_block = ram

[mem.flash]
base = 0x00000000
size = 256K

# 16 KB total; the top 1 KB is split out for EasyDMA buffers.
[mem.ram]
base = 0x20000000
size = 15K

[mem.ecb_ram]
base = 0x20003C00
size = 1K

# EasyDMA masters can only address RAM -- a flash pointer in ECBDATAPTR
# fails silently (the classic Nordic footgun). The bus window says so:
# reach outside RAM dies at target load, and verify's reach assert bounds
# the delivered address to RAM at the IKOS level.
[agent.ecb]
kind = dma
reach = ecb_ram
bus = 0x20000000..0x20004000
handoff = ECB.ECBDATAPTR
completes_by = ECB.EVENTS_ENDECB.READY
extent = 48

[interrupts]
TIMER0 = 8
